// Configuração do Prisma e Banco de Dados
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------
// TABELAS DO SISTEMA
// -------------------------------------------------

model Categoria {
  id        String   @id @default(uuid())
  nome      String   @unique
  criadoEm  DateTime @default(now())
}

model Cliente {
  id        String    @id @default(uuid())
  nome      String
  cpfCnpj   String?   
  email     String?
  whatsapp  String?
  status    String    @default("Ativo")
  
  conexoes  Conexao[] 
  chamados  Chamado[] 
  
  criadoEm  DateTime  @default(now())
}

model Conexao {
  id            String   @id @default(uuid())
  contratoMhnet String?
  endereco      String
  bairro        String?
  pppoe         String?
  senhaPpoe     String?
  
  clienteId     String
  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  chamados      Chamado[] 
}

model Chamado {
  id               String   @id @default(uuid())
  protocolo        String   
  
  clienteId        String?
  cliente          Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  
  conexaoId        String?
  conexao          Conexao? @relation(fields: [conexaoId], references: [id], onDelete: SetNull)

  nomeCliente      String   
  whatsCliente     String?
  enderecoCompleto String
  categoria        String
  motivo           String
  pppoe            String?
  senhaPpoe        String?
  contratoMhnet    String?
  obs              String?
  tecnico          String?
  
  abertoPor        String?  @default("Admin")
  resolucao        String?  
  prioridade       String   @default("Média")
  status           String   @default("novos") 

  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt
}

// -------------------------------------------------
// ARQUIVO MORTO (HISTÓRICO LEGADO)
// -------------------------------------------------
model HistoricoLegado {
  id              String   @id @default(uuid())
  cliente_nome    String
  resumo          String?  
  detalhes_brutos String   
  data_referencia String?  
  
  criadoEm        DateTime @default(now())
}

// -------------------------------------------------
// USUÁRIOS DO SISTEMA (LOGIN)
// -------------------------------------------------
model Usuario {
  id        String   @id @default(uuid())
  nome      String
  login     String   @unique
  senha     String   
  role      String   @default("TECNICO") 
  criadoEm  DateTime @default(now())
}