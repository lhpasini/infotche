// Configuração do Prisma e Banco de Dados
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------
// TABELAS DO SISTEMA
// -------------------------------------------------

model Categoria {
  id       String   @id @default(uuid())
  nome     String   @unique
  criadoEm DateTime @default(now())
}

model Cliente {
  id       String    @id @default(uuid())
  nome     String
  cidade    String?
  cpfCnpj  String?   
  email    String?
  whatsapp String?
  status   String    @default("Ativo")
  
  conexoes Conexao[] 
  chamados Chamado[] 
  
  criadoEm DateTime  @default(now())
}

model Conexao {
  id            String   @id @default(uuid())
  contratoMhnet String?
  endereco      String
  bairro        String?
  pppoe         String?
  senhaPpoe     String?
  
  clienteId     String
  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  chamados      Chamado[] 
}

model Chamado {
  id               String   @id @default(uuid())
  protocolo        String   
  
  clienteId        String?
  cliente          Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  
  conexaoId        String?
  conexao          Conexao? @relation(fields: [conexaoId], references: [id], onDelete: SetNull)

  nomeCliente      String
  cidadeCliente    String?   
  whatsCliente     String?
  enderecoCompleto String
  categoria        String
  motivo           String
  pppoe            String?
  senhaPpoe        String?
  contratoMhnet    String?
  obs              String?
  tecnico          String?
  
  abertoPor        String?  @default("Admin")
  resolucao        String?  
  prioridade       String   @default("Média")
  status           String   @default("novos") 

  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt
}

// -------------------------------------------------
// ARQUIVO MORTO (HISTÓRICO LEGADO)
// -------------------------------------------------
model HistoricoLegado {
  id              String   @id @default(uuid())
  cliente_nome    String
  resumo          String?  
  detalhes_brutos String   
  data_referencia String?  
  
  criadoEm        DateTime @default(now())
}

model ImportacaoArquivoMortoWhatsapp {
  id             String                         @id @default(uuid())
  nomeArquivo    String
  origem         String                         @default("WHATSAPP")
  totalMensagens Int                            @default(0)
  totalMidias    Int                            @default(0)
  criadoEm       DateTime                       @default(now())
  mensagens      ArquivoMortoWhatsappMensagem[]

  @@index([criadoEm])
}

model ArquivoMortoWhatsappMensagem {
  id            String                         @id @default(uuid())
  importacaoId  String
  importacao    ImportacaoArquivoMortoWhatsapp @relation(fields: [importacaoId], references: [id], onDelete: Cascade)
  dataMensagem  DateTime?
  dataTexto     String?
  autor         String?
  conteudo      String?
  tipoConteudo  String                         @default("TEXTO")
  arquivoNome   String?
  arquivoMime   String?
  arquivoUrl    String?
  driveFileId   String?
  mensagemBruta String?
  criadoEm      DateTime                       @default(now())

  @@index([dataMensagem])
  @@index([autor])
  @@index([arquivoNome])
}

// -------------------------------------------------
// USUÁRIOS DO SISTEMA (LOGIN)
// -------------------------------------------------
model Usuario {
  id       String   @id @default(uuid())
  nome     String
  login    String   @unique
  senha    String   
  role     String   @default("TECNICO") 
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  // Relação com as capturas feitas pelo técnico
  capturas                CapturaEquipamento[]
  atendimentosEquipamento AtendimentoEquipamento[]
}

// -------------------------------------------------
// NOVO MÓDULO: GESTÃO DE EQUIPAMENTOS (MOBILE)
// -------------------------------------------------
model CapturaEquipamento {
  id              String   @id @default(uuid())
  
  // Relacionamento com o técnico que fez a captura
  tecnicoId       String
  tecnico         Usuario  @relation(fields: [tecnicoId], references: [id])
  
  clienteNome     String
  tipoAtendimento String   // Ex: "Nova instalação", "Troca de equipamento"
  tipoEquipamento String   // Ex: "ONT", "ONU", "Roteador"
  macSerial       String
  fotoUrl         String?  // Link da imagem salva no Google Drive
  observacao      String?  // Campo extra para o técnico anotar algo, se precisar

  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
}

model AtendimentoEquipamento {
  id              String                      @id @default(uuid())
  tecnicoId       String
  tecnico         Usuario                     @relation(fields: [tecnicoId], references: [id])
  clienteNome     String
  tipoAtendimento String
  itens           AtendimentoEquipamentoItem[]
  criadoEm        DateTime                    @default(now())
  atualizadoEm    DateTime                    @updatedAt

  @@index([clienteNome])
  @@index([tecnicoId, criadoEm])
}

model AtendimentoEquipamentoItem {
  id                String                 @id @default(uuid())
  atendimentoId     String
  atendimento       AtendimentoEquipamento @relation(fields: [atendimentoId], references: [id], onDelete: Cascade)
  tipoEquipamento   String
  marca             String?
  modelo            String?
  codigoEquipamento String?
  macAddress        String?
  serialNumber      String?
  usuarioAcesso     String?
  senhaAcesso       String?
  imagemUrl         String?
  driveFileId       String?
  ocrTextoBruto     String?
  observacao        String?
  criadoEm          DateTime               @default(now())

  @@index([macAddress])
  @@index([serialNumber])
  @@index([codigoEquipamento])
}

model IntegracaoGoogleDrive {
  id           String   @id @default(uuid())
  email        String
  refreshToken String
  accessToken  String?
  scope        String?
  tokenType    String?
  expiryDate   DateTime?
  pastaId      String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model TipoAtendimentoEquipamento {
  id          String   @id @default(uuid())
  nome        String   @unique
  ativo       Boolean  @default(true)
  ordem       Int      @default(0)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([ativo, ordem])
}
